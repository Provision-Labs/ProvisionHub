# Keycloak DB
POSTGRES_KC_DB=keycloak
POSTGRES_KC_USER=keycloak
POSTGRES_KC_PASSWORD=change-me

# Control Plane DB
POSTGRES_CP_DB=provisionhub
POSTGRES_CP_USER=provisionhub
POSTGRES_CP_PASSWORD=change-me

# Keycloak Admin
KC_ADMIN=admin
KC_ADMIN_PASSWORD=change-me

# Keycloak / OIDC
KC_ISSUER=http://localhost:8280/realms/provisionhub
LOGOUT_REDIRECT=http://localhost:3000/

# Control Plane app
CP_ENV=production
CP_CLIENT_ID=provisionhub-api
CP_CLIENT_SECRET=change-me
CP_REDIRECT_URL=http://localhost:8180/auth/callback
CP_SCOPES=openid,profile,email
CP_SESSION_SECRET=change-me

# Production-only overrides
AUTH_DOMAIN=auth.example.com
CP_IMAGE_TAG=latest